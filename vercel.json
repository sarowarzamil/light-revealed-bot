{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/signup", "destination": "/server.js" },
    { "source": "/login", "destination": "/server.js" },
    { "source": "/sessions", "destination": "/server.js" },
    { "source": "/history/(.*)", "destination": "/server.js" },
    { "source": "/chat", "destination": "/server.js" },
    { "source": "/api/(.*)", "destination": "/server.js" },
    { "source": "/admin.html", "destination": "/server.js" }
  ]
}
