{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/admin.html", "dest": "/server.js" },
    { "src": "/signup", "dest": "/server.js" },
    { "src": "/login", "dest": "/server.js" },
    { "src": "/sessions", "dest": "/server.js" },
    { "src": "/history/(.*)", "dest": "/server.js" },
    { "src": "/chat", "dest": "/server.js" },
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
